# ─────────────────────────────────────────────────────────────────────────────
# 3rd Floor Labz — Live Executor environment template
#
# Copy this file to ".env" and fill in your own values.
# NEVER commit a real .env file. NEVER paste a private key or seed phrase here
# while sharing your screen or this repo.
#
# In DRY RUN mode (dryRunMode: true in live_config.json) NONE of these are
# required — no transactions are submitted, so no signer is needed.
# ─────────────────────────────────────────────────────────────────────────────

# Solana RPC endpoint used to read wallet balance and (later) submit swaps.
# A public endpoint works for reads; use a dedicated RPC for real execution.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─────────────────────────────────────────────────────────────────────────────
# REAL EXECUTION ONLY — leave BLANK for dry run.
#
# When you eventually move off dry run, the signer secret is read from the
# environment at runtime and is NEVER written to disk, logged, or echoed.
# Provide it as a base58 string or a JSON byte array path — your choice when
# you implement the real signer. Until then this stays empty.
#
# DO NOT paste a real secret into this example file.
# ─────────────────────────────────────────────────────────────────────────────
SOLANA_SIGNER_SECRET=

# The public address the signer must resolve to. The executor aborts if the
# loaded signer's public key does not match walletPublicAddress in
# live_config.json. This is a safety check, not a secret.
EXPECTED_WALLET_PUBLIC_ADDRESS=FXLGxPo4JAv1WGJy728WnZiEzxsP4XvLRF2y6KdoxBH6

# Solana Momentum Bot environment template
#
# Copy to .env only for local use.
# Keep all secrets blank in commits and migration artifacts.
# Do not enable live submission unless explicitly approved.

# ─── Dedicated RPC configuration (A4 reliability gate) ───────────────────────
# Do not commit real keys or private URLs. Leave every value blank in commits.
#
# Trust-critical executor RPC stages (priority fee, simulation, submission,
# confirmation, fill parse) REFUSE the public mainnet-beta fallback and require
# a dedicated (non-public) endpoint. Observation / dry-run may tolerate public
# fallback where allowed.
#
# Executor precedence (live_executor.js resolveRpcEndpoint) — first non-public
# match wins:
#   1. HELIUS_RPC_URL   — explicit dedicated Helius endpoint
#   2. SOLANA_RPC_URL   — explicit dedicated RPC endpoint
#   3. HELIUS_API_KEY   — used to DERIVE a Helius endpoint only if 1 and 2 are unset
#
# Configuring one of these does NOT prove A4: configured != verified dedicated.
# See Ori "A4.1 Dedicated RPC Config Contract — 2026-07-02" for the full rules.
HELIUS_RPC_URL=
SOLANA_RPC_URL=
HELIUS_API_KEY=

# Legacy / ambiguous — NOT authoritative for A4.
# RPC_URL is NOT consumed by the executor RPC path (live_executor.js) or the
# dashboard A4 readiness panel. It is referenced only by validate_live_preflight.js.
# Do NOT rely on RPC_URL for A4 dedicated-RPC readiness; use the variables above.
RPC_URL=

# Optional Jupiter API key for quote/build requests.
JUPITER_API_KEY=

# Wallet identity checks. This is a public address only, not a secret.
EXPECTED_WALLET_PUBLIC_ADDRESS=

# Live-only signer material.
# Must be a 64-byte JSON array if ever approved for live use.
# Never paste a seed phrase or private key text here.
SOLANA_SIGNER_SECRET=

# Live-only arming switches. Keep blank unless explicitly approved.
FOMO_ENABLE_LIVE_SUBMISSION=
FOMO_ALLOW_LOOP_LIVE=

# Dry-run probe utility variables for tools/fomo_dry_run_probe.mjs.
DRY_RUN_PUBKEY=
INPUT_LAMPORTS=
SLIPPAGE_BPS=
ASSUMED_CU=
PRIORITY_FEE=
